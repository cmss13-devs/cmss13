/obj/structure/prop{
	name = "\improper AIM-90E 'Headlock''";
	desc = "The AIM-90E is a short-ranged air-to-air missile optimized for dogfight. Its engineered to accelerate to hypersonic speeds after launch and then glides the remaining distance to the intended target. Its guided by a dual optical/active radar seeker. This one is designed for use exclusively by areospace fighters such as the EVAC-3.";
